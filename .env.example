# 复制此文件为 .env 后填写实际值
# cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────
DEBUG=false

# ── MySQL ─────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
MYSQL_DB=course_arrange

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 排课组占用 Redis DB 2（broker）和 DB 3（result）
CELERY_BROKER_DB=2
CELERY_RESULT_DB=3

# ── 上游微服务（基础信息组，第一子系统）──────────────────────────────────────
INFO_SERVICE_BASE_URL=http://info-service:8000
INFO_SERVICE_TEACHERS_PATH=/api/v1/teachers
INFO_SERVICE_COURSES_PATH=/api/v1/courses
INFO_SERVICE_CLASSROOMS_PATH=/api/v1/classrooms

# ── 认证 Header（网关透传）────────────────────────────────────────────────────
AUTH_HEADER_USER_ID=X-User-Id
AUTH_HEADER_USER_ROLE=X-User-Role
ROLE_ADMIN=ADMIN
ROLE_TEACHER=TEACHER
ROLE_STUDENT=STUDENT
